# Dockerfile.dev
# http3-sports-api — Development Container
#
# Stack: official Dev Containers .NET 10 image on Ubuntu 24.04 (Noble)
# Tools: GitHub CLI, network diagnostics
#

FROM mcr.microsoft.com/devcontainers/dotnet:10.0-noble

# ── System dependencies ──────────────────────────────────────────────────────
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        unzip \
        gnupg \
        # Network diagnostics — used to verify QUIC/UDP traffic
        net-tools \
        procps \
        iproute2 \
        iputils-ping \
        netcat-openbsd \
        telnet \
        dnsutils \
        traceroute \
        # General tooling
        jq \
        ripgrep \
        git && \
    rm -rf /var/lib/apt/lists/*

# ── GitHub CLI ───────────────────────────────────────────────────────────────
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | gpg --dearmor -o /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] \
        https://cli.github.com/packages stable main" \
        | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
    apt-get update && \
    apt-get install -y gh && \
    rm -rf /var/lib/apt/lists/*

# ── Sanity checks ────────────────────────────────────────────────────────────
RUN dotnet --version && gh --version

# ── Working directory ────────────────────────────────────────────────────────
WORKDIR /workspaces/http3-sports-api
