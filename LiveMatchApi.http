@LiveMatchApi_Host = http://localhost:5000

GET {{LiveMatchApi_Host}}/
Accept: application/json

###

GET {{LiveMatchApi_Host}}/health
Accept: application/json

###

GET {{LiveMatchApi_Host}}/api/matches/live
Accept: application/json

###

GET {{LiveMatchApi_Host}}/api/matches/upcoming
Accept: application/json

###

# Replace {fixtureId} with a real fixture id from /api/matches/live or /api/matches/upcoming
GET {{LiveMatchApi_Host}}/api/match/{fixtureId}/stats
Accept: application/json

###

GET {{LiveMatchApi_Host}}/api/highlights/feed
Accept: application/json

###

GET {{LiveMatchApi_Host}}/api/highlights/arsenal
Accept: application/json

###

GET {{LiveMatchApi_Host}}/api/benchmark/ping
Accept: application/json

###

GET {{LiveMatchApi_Host}}/api/benchmark/payload/100

###

GET {{LiveMatchApi_Host}}/api/benchmark/panel/slow?delayMs=1500
Accept: application/json
